export ISSUE_NUMBER=${ISSUE_NUMBER}
export GITHUB_ISSUE_URL=${GITHUB_ISSUE_URL}

# GH_TOKEN in the sandbox is the job's github.token.
# The agent uses this ONLY for reads (gh issue view, gh pr view).
# Writes are blocked by disallowedTools + sandbox network policy.
# The separate PUSH_TOKEN (runner_env) never enters the sandbox.
export GH_TOKEN=${GH_TOKEN}

export GIT_AUTHOR_NAME="fullsend-code"
export GIT_AUTHOR_EMAIL="fullsend-code@users.noreply.github.com"
export GIT_COMMITTER_NAME="fullsend-code"
export GIT_COMMITTER_EMAIL="fullsend-code@users.noreply.github.com"

# Go toolchain — sandbox doesn't inherit Docker ENV, so set PATH explicitly.
# ${PATH} is expanded on the runner side (expand: true) before reaching sandbox.
export PATH="/usr/local/go/bin:${PATH}"
export GOPATH="/sandbox/go"
export GOMODCACHE="/sandbox/go/pkg/mod"

# SSL certs — git uses system OpenSSL which needs a CA bundle.
# Debian/Ubuntu path; if this doesn't exist, git falls back to its default search.
export GIT_SSL_CAINFO=/etc/ssl/certs/ca-certificates.crt
